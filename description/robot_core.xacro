<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="GantBot"> 
    <xacro:include filename="example_include.xacro" />
    <xacro:include filename="example_gazebo.xacro" />
    <link name="world"></link>
    <joint name="base_joint" type="fixed">
        <origin xyz="1.5 1.0 0" rpy="0 0 0"/>
        <parent link="world"/>
        <child link="base_link"/> 
        <dynamics damping="1000000" friction="10000000"/>       
    </joint>
    <link name="base_link">
        <visual>
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
            <geometry>
                <box size="5 5 0.1" />
            </geometry>
            <material name="green">
                <color rgba="0.2 1 0.2 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
            <geometry>
                <box size="5 5 0.1" />
            </geometry>
        </collision>
        <xacro:inertial_box mass="10" x="5" y="5" z="0.1">
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>
    
    <joint name="pilar1_joint" type="fixed">
        <origin xyz="2.375 2.375 0.1" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="pilar1_link"/>
        <dynamics damping="1000000" friction="10000000"/>   
    </joint>

    <link name="pilar1_link">
        <visual>
            <origin xyz="0 0 1" rpy="0 0 0"/>
            <geometry>
                <box size="0.25 0.25 2" />
            </geometry>
            <material name="green">
                <color rgba="0.2 1 0.2 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 1" rpy="0 0 0"/>
            <geometry>
                <box size="0.25 0.25 2" />
            </geometry>
        </collision>
        <xacro:inertial_box mass="2" x="0.5" y="0.25" z="0.15">
            <origin xyz="0 0 1" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <joint name="pilar2_joint" type="fixed">
        <origin xyz="-2.375 2.375 0.1" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="pilar2_link"/>
        <dynamics damping="1000000" friction="10000000"/>   
    </joint>

    <link name="pilar2_link">
        <visual>
            <origin xyz="0 0 1" rpy="0 0 0"/>
            <geometry>
                <box size="0.25 0.25 2" />
            </geometry>
            <material name="green">
                <color rgba="0.2 1 0.2 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 1" rpy="0 0 0"/>
            <geometry>
                <box size="0.25 0.25 2" />
            </geometry>
        </collision>
        <xacro:inertial_box mass="2" x="0.5" y="0.25" z="0.15">
            <origin xyz="0 0 1" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>
      
     <joint name="pilar3_joint" type="fixed">
        <origin xyz="2.375 -2.375 0.1" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="pilar3_link"/>
        <dynamics damping="1000000" friction="10000000"/>   
    </joint>

    <link name="pilar3_link">
        <visual>
            <origin xyz="0 0 1" rpy="0 0 0"/>
            <geometry>
                <box size="0.25 0.25 2" />
            </geometry>
            <material name="green">
                <color rgba="0.2 1 0.2 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 1" rpy="0 0 0"/>
            <geometry>
                <box size="0.25 0.25 2" />
            </geometry>
        </collision>
        <xacro:inertial_box mass="2" x="0.5" y="0.25" z="0.15">
            <origin xyz="0 0 1" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <joint name="pilar4_joint" type="fixed">
        <origin xyz="-2.375 -2.375 0.1" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="pilar4_link"/>
        <dynamics damping="1000000" friction="10000000"/>   
    </joint>

    <link name="pilar4_link">
        <visual>
            <origin xyz="0 0 1" rpy="0 0 0"/>
            <geometry>
                <box size="0.25 0.25 2" />
            </geometry>
            <material name="green">
                <color rgba="0.2 1 0.2 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 1" rpy="0 0 0"/>
            <geometry>
                <box size="0.25 0.25 2" />
            </geometry>
        </collision>
        <xacro:inertial_box mass="2" x="0.5" y="0.25" z="0.15">
            <origin xyz="0 0 1" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <joint name="edge1_joint" type="fixed">
        <origin xyz="0 -2.375 2.125" rpy="0 0 0"/>
        <parent link="pilar1_link"/>
        <child link="edge1_link"/>
        <dynamics damping="1000000" friction="10000000"/>   
    </joint>

    <link name="edge1_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.25 5 0.25" />
            </geometry>
            <material name="green">
                <color rgba="0.2 1 0.2 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.25 5 0.25" />
            </geometry>
        </collision>
        <xacro:inertial_box mass="1" x="0.5" y="0.25" z="0.15">
            <origin xyz="0 0 0.075" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>
     
     <joint name="edge2_joint" type="fixed">
        <origin xyz="0 -2.375 2.125" rpy="0 0 0"/>
        <parent link="pilar2_link"/>
        <child link="edge2_link"/>
        <dynamics damping="1000000" friction="10000000"/>   
    </joint>

    <link name="edge2_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.25 5 0.25" />
            </geometry>
            <material name="green">
                <color rgba="0.2 1 0.2 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.25 5 0.25" />
            </geometry>
        </collision>
        <xacro:inertial_box mass="1" x="0.5" y="0.25" z="0.15">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>
    
    <joint name="y_joint" type="prismatic">
        <origin xyz="0.125 0 0" rpy="0 0 0"/>
        <parent link="edge2_link"/>
        <child link="y_link"/>
        <axis xyz="0 1 0"/>
        <dynamics damping="5.0" friction="1.0"/>
        <limit lower="-2.25" upper="2.25" velocity="1" effort="100"/> 
    </joint>

    <link name="y_link">
        <visual>
            <origin xyz="2.25 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="4.5 0.25 0.25" />
            </geometry>
            <material name="blue">
                <color rgba="0.2 1 0.2 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="2.25 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="4.5 0.25 0.25" />
            </geometry> 
        </collision>
        <xacro:inertial_box mass="0.5" x="0.5" y="0.25" z="0.15">
            <origin xyz="2.25 0 0" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <joint name="x_joint" type="prismatic">
        <origin xyz="2.25 0.25 0" rpy="0 0 0"/>
        <parent link="y_link"/>
        <child link="x_link"/>
        <axis xyz="1 0 0"/>
        <dynamics damping="5.0" friction="1.0"/>
        <limit lower="-2.1" upper="2.1" velocity="1" effort="100"/> 
    </joint>

    <link name="x_link">
        <visual>
            <origin xyz="0 0 -0.6" rpy="0 0 0"/>
            <geometry>
                <box size="0.25 0.25 1.75" />
            </geometry>
            <material name="blue">
                <color rgba="0.2 1 0.2 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 -0.6" rpy="0 0 0"/>
            <geometry>
                <box size="0.25 0.25 1.75" />
            </geometry>
        </collision>
        <xacro:inertial_box mass="0.5" x="0.5" y="0.25" z="0.15">
            <origin xyz="0 0 -0.6" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <joint name="z_joint" type="prismatic">
        <origin xyz="0 0.25 0" rpy="0 0 0"/>
        <parent link="x_link"/>
        <child link="z_link"/>
        <axis xyz="0 0 1"/>
        <dynamics damping="5.0" friction="1.0"/>
        <limit lower="-1" upper="0.2" velocity="1" effort="100"/> 
    </joint>

    <link name="z_link">
        <visual>
            <origin xyz="0 0 -0.6" rpy="0 0 0"/>
            <geometry>
                <box size="0.25 0.25 0.4" />
            </geometry>
            <material name="orange"/>
        </visual>
        <collision>
            <origin xyz="0 0 -0.6" rpy="0 0 0"/>
            <geometry>
                <box size="0.25 0.25 0.4"/>
            </geometry>
        </collision>
        <xacro:inertial_box mass="0.2" x="0.5" y="0.25" z="0.15">
            <origin xyz="0 0 -0.6" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

</robot>